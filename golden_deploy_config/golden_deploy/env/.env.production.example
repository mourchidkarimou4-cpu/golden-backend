# ══════════════════════════════════════════════════════════
# GOLDEN Investissement — Variables d'environnement PRODUCTION
# ══════════════════════════════════════════════════════════
#
# Ce fichier est un GUIDE de référence.
# Ne jamais committer ce fichier avec de vraies valeurs !
#
# → Render    : Dashboard → golden-api → Environment
# → Netlify   : Dashboard → Site → Environment variables
# ══════════════════════════════════════════════════════════


# ─────────────────────────────────────────────────────────
# 1. DJANGO (à renseigner dans Render)
# ─────────────────────────────────────────────────────────

DJANGO_SETTINGS_MODULE=config.settings.prod

# Générer avec : python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=GENERER_UNE_CLE_ICI

DEBUG=False

# Render génère automatiquement : golden-api.onrender.com
ALLOWED_HOSTS=golden-api.onrender.com


# ─────────────────────────────────────────────────────────
# 2. SUPABASE — BASE DE DONNÉES PostgreSQL
# ─────────────────────────────────────────────────────────
# Aller sur : supabase.com → Ton projet → Settings → Database
# Section "Connection string" → choisir "URI"

DATABASE_URL=postgresql://postgres.[REF]:[MOT_DE_PASSE]@aws-0-eu-west-2.pooler.supabase.com:6543/postgres

# ─────────────────────────────────────────────────────────
# 3. SUPABASE — STORAGE (compatible S3)
# ─────────────────────────────────────────────────────────
# Aller sur : supabase.com → Ton projet → Settings → Storage
# Activer l'accès S3 compatible

USE_S3=True

# supabase.com → Settings → API → Project API keys → service_role
AWS_ACCESS_KEY_ID=TON_PROJECT_REF_SUPABASE
AWS_SECRET_ACCESS_KEY=TON_SERVICE_ROLE_KEY

AWS_STORAGE_BUCKET_NAME=golden-files

# Format : https://[PROJECT_REF].supabase.co/storage/v1/s3
AWS_S3_ENDPOINT_URL=https://TON_PROJECT_REF.supabase.co/storage/v1/s3


# ─────────────────────────────────────────────────────────
# 4. UPSTASH REDIS (gratuit — pour Celery)
# ─────────────────────────────────────────────────────────
# Créer un compte sur : upstash.com
# Créer une base Redis → copier "REDIS_URL (TLS)"

REDIS_URL=rediss://default:[MOT_DE_PASSE]@[REGION].upstash.io:6379
CELERY_BROKER_URL=rediss://default:[MOT_DE_PASSE]@[REGION].upstash.io:6379
CELERY_RESULT_BACKEND=rediss://default:[MOT_DE_PASSE]@[REGION].upstash.io:6379


# ─────────────────────────────────────────────────────────
# 5. CORS & FRONTEND
# ─────────────────────────────────────────────────────────
# Ton URL Netlify générée automatiquement
CORS_ALLOWED_ORIGINS=https://golden-invest.netlify.app
FRONTEND_URL=https://golden-invest.netlify.app


# ─────────────────────────────────────────────────────────
# 6. EMAIL — SendGrid (gratuit 100 emails/jour)
# ─────────────────────────────────────────────────────────
# Créer un compte sur : sendgrid.com → API Keys
SENDGRID_API_KEY=SG.XXXXXXXXXXXXXXXX
DEFAULT_FROM_EMAIL=noreply@golden-invest.netlify.app


# ─────────────────────────────────────────────────────────
# 7. PAIEMENT — CinetPay (optionnel MVP)
# ─────────────────────────────────────────────────────────
CINETPAY_API_KEY=
CINETPAY_SITE_ID=


# ─────────────────────────────────────────────────────────
# 8. NETLIFY — Variables frontend React
# ─────────────────────────────────────────────────────────
# À ajouter dans : Netlify Dashboard → Site → Environment variables

# URL de l'API Django sur Render
VITE_API_URL=https://golden-api.onrender.com/api/v1

# URL publique Supabase
VITE_SUPABASE_URL=https://TON_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=TON_ANON_KEY
