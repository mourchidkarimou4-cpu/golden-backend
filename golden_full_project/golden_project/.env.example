# ─── DJANGO ───────────────────────────────────────────────
SECRET_KEY=change-me-in-production-use-get_random_secret_key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── BASE DE DONNÉES ──────────────────────────────────────
DATABASE_URL=postgres://golden_user:golden_pass@localhost:5432/golden_db

# ─── REDIS / CELERY ───────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ─── STOCKAGE S3 ──────────────────────────────────────────
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=golden-investissement
AWS_S3_REGION_NAME=eu-west-3

# ─── EMAIL ────────────────────────────────────────────────
SENDGRID_API_KEY=
DEFAULT_FROM_EMAIL=noreply@goldeninvest.com

# ─── PAIEMENT ─────────────────────────────────────────────
CINETPAY_API_KEY=
CINETPAY_SITE_ID=
CINETPAY_BASE_URL=https://api-checkout.cinetpay.com/v2

# ─── SIGNATURE ÉLECTRONIQUE ───────────────────────────────
YOUSIGN_API_KEY=
YOUSIGN_BASE_URL=https://api.yousign.app/v3

# ─── FRONTEND ─────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── JWT ──────────────────────────────────────────────────
ACCESS_TOKEN_LIFETIME_MINUTES=15
REFRESH_TOKEN_LIFETIME_DAYS=7
